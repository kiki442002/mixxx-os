{
	"notes": [
		"Cooker menu for Raspberry Pi 4 (64-bit) with Weston (Wayland).",
		"Custom layer meta-mixxx for the Mixxx image.",
		"Build with: cooker cook menu.json"
	],

	"sources": [
		{
			"url": "git://git.yoctoproject.org/poky",
			"branch": "scarthgap",
			"rev": "yocto-5.0.12"
		},
		{
			"url": "git://git.openembedded.org/meta-openembedded",
			"branch": "scarthgap",
			"rev": "f1f24826"
		},
		{
			"url": "git://git.yoctoproject.org/meta-raspberrypi",
			"branch": "scarthgap",
			"rev": "8767e2ff"
		},
		{
			"url": "git://code.qt.io/yocto/meta-qt6",
			"branch": "6.10",
			"rev": "6.10"
		}
	],

	"layers": [
        "../meta-mixxx",
		"poky/meta",
		"poky/meta-poky",
		"poky/meta-yocto-bsp",
		"meta-openembedded/meta-oe",
		"meta-openembedded/meta-python",
		"yocto/meta-qt6"
	],

	"builds": {

		"rpi4": {
			"target": "mixxx-image",

			"layers": [
				"meta-raspberrypi"
			],

			"local.conf": [
				"MACHINE = 'raspberrypi4-64'",
				"DISTRO = 'mixxx-os'",
				"VC4GRAPHICS = '1'"
			]
		}
	}
}
